NEXT_PUBLIC_SOLANA_ORDERBOOK_PROGRAM_ID=

# Reown (WalletConnect) — enables multi-wallet modal
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Coinbase Developer Platform (MiniKit / Base App)
NEXT_PUBLIC_CDP_CLIENT_API_KEY=
NEXT_PUBLIC_MINIKIT_PROJECT_ID=

# Auth hardening
AUTH_ALLOWED_ORIGINS=http://localhost:3000
