# Relay44 Web Configuration

# API
NEXT_PUBLIC_API_URL=http://localhost:8080/v1
NEXT_PUBLIC_API_PROXY_URL=/api/proxy
NEXT_PUBLIC_API_FALLBACK_URL=
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_CHAIN_MODE=base
NEXT_PUBLIC_SITE_URL=https://relay44.com
NEXT_PUBLIC_DISABLE_PWA=false
NEXT_PUBLIC_READ_ONLY_MODE=false

# Base chain
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_CHAIN_ID=8453
NEXT_PUBLIC_SIWE_DOMAIN=localhost:3000
NEXT_PUBLIC_RELAY_TOKEN_ADDRESS=0x580fF5Ae64eC792A949c6123386A8A936c7EBB07
NEXT_PUBLIC_RELAY_STAKING_ADDRESS=0x709D6006f026950b531d4883260c8416650c5AB7
NEXT_PUBLIC_MARKET_CORE_ADDRESS=0xc9259a18696Ecbf7636C1a01F40Bc9d47e249AE8
NEXT_PUBLIC_ORDER_BOOK_ADDRESS=0xFe8aA303Ab953037023b12326D354f6d2484D4ce
NEXT_PUBLIC_AGENT_RUNTIME_ADDRESS=0xC44d686548513FF2a921201fa0811B1f30AA1a65
NEXT_PUBLIC_COLLATERAL_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_COLLATERAL_VAULT_ADDRESS=0x4420dd803e6E363e6af079e6b77CA03B93f8dAe0

# Solana chain metadata
