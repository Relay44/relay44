# Context Graph Service
CONTEXT_GRAPH_PORT=3010
CONTEXT_GRAPH_DATA_DIR=./data

# DKG Connection
DKG_ENDPOINT=
DKG_PRIVATE_KEY=
DKG_BLOCKCHAIN=base:8453
DKG_RPC_URL=
CONTEXT_GRAPH_PARANET_UAL=
CONTEXT_GRAPH_WORKSPACE_UAL=
DKG_EPOCHS=12

# Polymarket APIs (public, no auth needed)
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API=https://clob.polymarket.com

# LLM (for claim extraction)
ANTHROPIC_API_KEY=
CONTEXT_GRAPH_LLM_MODEL=claude-sonnet-4-5-20250514
CONTEXT_GRAPH_LLM_ENABLED=true

# Social data (optional)
SOCIAL_DATA_API_KEY=

# News API (optional)
NEWS_API_KEY=
GOOGLE_FACTCHECK_API_KEY=

# Feature flags
CONTEXT_GRAPH_DKG_ENABLED=true
CONTEXT_GRAPH_AUTO_HEDGE_ENABLED=false
