{
  "name": "relay44",
  "version": "0.1.0",
  "description": "Autonomous market infrastructure on Base and Solana",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Relay44/relay44.git"
  },
  "homepage": "https://relay44.com",
  "keywords": [
    "prediction-markets",
    "base",
    "solana",
    "defi",
    "agents",
    "orderbook",
    "x402"
  ],
  "author": "Relay44 <hello@relay44.com>",
  "contributors": [
    "Mizuki"
  ],
  "private": true,
  "workspaces": [
    "sdk/protocol",
    "sdk/agent"
  ],
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test": "echo \"No root tests configured\"",
    "web:dev:watch": "bash scripts/web-dev.sh",
    "ops:silo-check": "./scripts/verify-project-silo.sh",
    "ops:silo-check:strict": "SILO_CHECK_INCLUDE_DOCS=1 ./scripts/verify-project-silo.sh",
    "ops:repo-standards": "bash scripts/verify-public-repo-standards.sh",
    "ops:no-internal-assets": "bash scripts/verify-no-internal-assets.sh staged",
    "ops:no-internal-assets:tracked": "bash scripts/verify-no-internal-assets.sh tracked",
    "ops:no-native-selects": "bash scripts/verify-no-native-selects.sh staged",
    "ops:no-native-selects:tracked": "bash scripts/verify-no-native-selects.sh tracked",
    "ops:commit-hygiene": "bash scripts/verify-commit-hygiene-branch.sh",
    "ops:commit-hygiene:all": "bash scripts/verify-commit-hygiene.sh --history-all",
    "ops:commit-hygiene:staged": "bash scripts/verify-commit-hygiene.sh --staged",
    "ops:hooks:install": "./scripts/install-git-hooks.sh",
    "ops:hooks:verify": "./scripts/verify-git-hooks.sh",
    "ops:rewrite-branch-commits": "bash scripts/rewrite-branch-commits.sh",
    "push:safe": "./scripts/push-safe.sh",
    "vendor:singularity:dual-core": "bash scripts/vendor-singularity-dual-core.sh",
    "launch:config": "node scripts/validate-launch-config.mjs --mode=production --write-report",
    "launch:config:dev-strict": "node scripts/validate-launch-config.mjs --mode=staging --allow-missing-secrets --write-report",
    "launch:config:prod-strict": "node scripts/validate-launch-config.mjs --mode=production --write-report",
    "launch:addresses": "node scripts/validate-address-manifest.mjs --environment=production --write-report",
    "launch:addresses:staging": "node scripts/validate-address-manifest.mjs --environment=staging --write-report",
    "launch:readiness": "bash scripts/launch-readiness.sh --mode=staging --allow-missing-secrets",
    "launch:readiness:strict": "bash scripts/launch-readiness.sh --strict --mode=production --require-dx-snapshot",
    "launch:readiness:strict:dx": "npm run launch:readiness:strict",
    "launch:summary": "bash scripts/generate-launch-summary.mjs",
    "launch:e2e": "npm run launch:readiness:strict && npm run production:gates:strict",
    "launch:ops:monitor": "node scripts/launch-ops-monitor.mjs",
    "launch:ops:freeze": "node scripts/launch-ops-freeze.mjs",
    "launch:freeze:guard": "node scripts/launch-freeze-guard.mjs",
    "launch:ops:phase1": "bash scripts/launch-ops-execute.sh --phase=phase1",
    "launch:ops:phase2": "bash scripts/launch-ops-execute.sh --phase=phase2",
    "launch:ops:phase3": "bash scripts/launch-ops-execute.sh --phase=phase3",
    "launch:ops:phase4": "bash scripts/launch-ops-execute.sh --phase=phase4",
    "launch:ops:all": "bash scripts/launch-ops-execute.sh --phase=all",
    "ops:health-monitor": "node scripts/health-monitor.mjs",
    "creator-economics:materializer": "node scripts/creator-economics-materializer.mjs",
    "synthetic:check": "bash scripts/synthetic-monitor.mjs",
    "openclaw:e2e": "node scripts/openclaw-e2e-readiness.mjs",
    "openclaw:pack": "node scripts/generate-openclaw-pack.mjs",
    "base:smoke:sepolia": "node scripts/base-sepolia-smoke.mjs",
    "base:web:e2e:sepolia": "node scripts/base-sepolia-web-smoke.mjs",
    "base:seed:pilot": "bash scripts/base-seed-pilot.sh --network mainnet",
    "load:baseline:report": "node scripts/load-baseline-report.mjs",
    "production:gates": "node scripts/production-loop-report.mjs",
    "production:gates:strict": "node scripts/production-loop-report.mjs --strict",
    "base:wallets:status": "bash scripts/base-wallet-status.sh --network both",
    "base:fund:sepolia": "bash scripts/base-distribute-funds.sh --network sepolia",
    "base:fund:mainnet": "bash scripts/base-distribute-funds.sh --network mainnet",
    "base:smoke:mainnet": "bash scripts/base-mainnet-smoke.sh --network mainnet",
    "base:smoke:mainnet:dry": "bash scripts/base-mainnet-smoke.sh --network mainnet --dry-run",
    "solana:smoke": "node scripts/solana-program-smoke.mjs",
    "agents:executor": "npm run agents:operator",
    "agents:executor:sepolia": "BASE_CHAIN_ID=84532 node scripts/base-agent-operator.mjs",
    "agents:executor:dry": "BASE_AGENT_OPERATOR_DRY_RUN=true node scripts/base-agent-operator.mjs",
    "alpha-cohort:seed": "node scripts/alpha-cohort-seed.mjs",
    "alpha-cohort:health": "node scripts/alpha-cohort-health.mjs",
    "paper-cohort:start": "node scripts/paper-cohort-start.mjs",
    "paper-cohort:tick": "node scripts/paper-cohort-tick.mjs",
    "paper-cohort:run": "node scripts/paper-cohort-run.mjs",
    "paper-cohort:report": "node scripts/paper-cohort-report.mjs",
    "farcaster-bot:tick": "node scripts/farcaster-bot-tick.mjs",
    "external-runner:tick": "node scripts/external-runner-tick.mjs",
    "external-runner:run": "node scripts/external-runner-run.mjs",
    "external-state:migrate": "node scripts/migrate-external-state.mjs",
    "decision-runner:tick": "node scripts/decision-runner-tick.mjs",
    "agents:operator": "node scripts/base-agent-operator.mjs",
    "agents:operator:dry": "BASE_AGENT_OPERATOR_DRY_RUN=true node scripts/base-agent-operator.mjs",
    "bootstrap:backfill": "node scripts/bootstrap-backfill.mjs",
    "seed:production": "node scripts/seed-production.mjs",
    "leaderboard:compute": "node scripts/leaderboard-compute-tick.mjs",
    "edge-scanner:tick": "node scripts/edge-scanner-tick.mjs",
    "edge-scanner:dry": "EDGE_SCANNER_DRY_RUN=true node scripts/edge-scanner-tick.mjs",
    "polymarket-indexer:tick": "node scripts/polymarket-indexer-tick.mjs",
    "polymarket-indexer:run": "node scripts/polymarket-indexer-run.mjs",
    "polymarket:forwarder": "node services/polymarket-forwarder/server.mjs",
    "x402:facilitator": "node services/x402-facilitator/server.mjs",
    "x402:smoke": "node scripts/x402-smoke.mjs",
    "launch:onchain:verify": "node scripts/verify-base-mainnet-deployment.mjs",
    "matcher:worker": "bash scripts/base-matcher-worker.sh --network mainnet",
    "matcher:worker:sepolia": "bash scripts/base-matcher-worker.sh --network sepolia",
    "matcher:worker:dry": "bash scripts/base-matcher-worker.sh --network mainnet --dry-run --once",
    "payouts:worker": "bash scripts/base-global-payout-worker.sh --network mainnet",
    "payouts:worker:sepolia": "bash scripts/base-global-payout-worker.sh --network sepolia",
    "payouts:worker:dry": "bash scripts/base-global-payout-worker.sh --network mainnet --dry-run --once",
    "payouts:worker:auto-withdraw": "bash scripts/base-global-payout-worker.sh --network mainnet --auto-withdraw true",
    "payouts:worker:auto-withdraw:sepolia": "bash scripts/base-global-payout-worker.sh --network sepolia --auto-withdraw true",
    "mcp:server": "node scripts/mcp-server.mjs",
    "xmtp:bridge": "node services/xmtp-bridge/server.mjs",
    "evm:build": "forge build --root evm",
    "evm:test": "forge test --root evm",
    "evm:fmt": "forge fmt --root evm",
    "sdk:protocol:generate": "npm --workspace @relay44/protocol run generate",
    "sdk:protocol:check": "npm --workspace @relay44/protocol run check",
    "sdk:protocol:build": "npm --workspace @relay44/protocol run build",
    "sdk:agent:build": "npm --workspace @relay44/agent-sdk run build",
    "sdk:build": "npm run sdk:protocol:build && npm run sdk:agent:build",
    "sdk:check": "npm run sdk:protocol:check && npm run sdk:build",
    "evm:deploy:base-sepolia": "forge script script/DeployCore.s.sol:DeployCoreScript --root evm --rpc-url $BASE_SEPOLIA_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:deploy:base": "forge script script/DeployCore.s.sol:DeployCoreScript --root evm --rpc-url $BASE_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:deploy:programs:base-sepolia": "forge script script/DeployPrograms.s.sol:DeployProgramsScript --root evm --rpc-url $BASE_SEPOLIA_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:deploy:programs:base": "forge script script/DeployPrograms.s.sol:DeployProgramsScript --root evm --rpc-url $BASE_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:deploy:timelock:base": "forge script script/DeployTimelock.s.sol:DeployTimelockScript --root evm --rpc-url $BASE_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:deploy:timelock:base-sepolia": "forge script script/DeployTimelock.s.sol:DeployTimelockScript --root evm --rpc-url $BASE_SEPOLIA_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:handoff:timelock:base": "forge script script/HandoffToTimelock.s.sol:HandoffToTimelockScript --root evm --rpc-url $BASE_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast",
    "evm:handoff:timelock:base-sepolia": "forge script script/HandoffToTimelock.s.sol:HandoffToTimelockScript --root evm --rpc-url $BASE_SEPOLIA_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast",
    "evm:deploy:programs:sepolia:run": "bash scripts/base-deploy-programs.sh --network sepolia",
    "evm:deploy:programs:mainnet:run": "bash scripts/base-deploy-programs.sh --network mainnet"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-solidity": "^2.2.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@coinbase/coinbase-sdk": "^0.25.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.10.0",
    "@x402/express": "^2.10.0",
    "@xmtp/agent-sdk": "^2.2.0",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "pg": "^8.16.3",
    "viem": "^2.48.4",
    "zod": "^4.3.6"
  },
  "overrides": {
    "axios": "^1.15.0",
    "hono": "^4.12.14",
    "@hono/node-server": "^1.19.13",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^4.0.4",
    "express-rate-limit": "^8.3.2",
    "elliptic": "^6.6.1"
  }
}
