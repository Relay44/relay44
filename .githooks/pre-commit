#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if [[ ! -x ./scripts/verify-project-silo.sh ]]; then
  echo "Missing silo checker: scripts/verify-project-silo.sh"
  exit 1
fi

SILO_CHECK_INCLUDE_DOCS=1 ./scripts/verify-project-silo.sh

if [[ ! -x ./scripts/verify-public-repo-standards.sh ]]; then
  echo "Missing public repo standards checker: scripts/verify-public-repo-standards.sh"
  exit 1
fi

./scripts/verify-public-repo-standards.sh

if [[ ! -x ./scripts/verify-commit-hygiene.sh ]]; then
  echo "Missing commit hygiene checker: scripts/verify-commit-hygiene.sh"
  exit 1
fi

./scripts/verify-commit-hygiene.sh --staged

if [[ ! -x ./scripts/verify-no-internal-assets.sh ]]; then
  echo "Missing internal asset checker: scripts/verify-no-internal-assets.sh"
  exit 1
fi

./scripts/verify-no-internal-assets.sh staged

if [[ ! -x ./scripts/verify-no-native-selects.sh ]]; then
  echo "Missing custom select checker: scripts/verify-no-native-selects.sh"
  exit 1
fi

./scripts/verify-no-native-selects.sh staged
