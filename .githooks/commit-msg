#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if [[ ! -x ./scripts/verify-commit-hygiene.sh ]]; then
  echo "Missing commit hygiene checker: scripts/verify-commit-hygiene.sh"
  exit 1
fi

if [[ ! -x ./scripts/normalize-commit-message.sh ]]; then
  echo "Missing commit message normalizer: scripts/normalize-commit-message.sh"
  exit 1
fi

./scripts/normalize-commit-message.sh "$1"
./scripts/verify-commit-hygiene.sh --commit-msg-file "$1"
