# Relay44 Environment Configuration (Base + Solana)
# Copy this file to .env and fill in your values

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=relay44
POSTGRES_PORT=5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# Chain mode
CHAIN_MODE=base

# Base
BASE_RPC_URL=https://mainnet.base.org
BASE_RPC_FALLBACK_URLS=
BASE_INDEXER_RPC_URL=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_WS_URL=wss://mainnet.base.org
BASE_CHAIN_ID=8453
BASE_SEPOLIA_CHAIN_ID=84532
BASESCAN_API_KEY=
SIWE_DOMAIN=localhost:3000
FOUNDRY_ACCOUNT=base-deployer
BASE_ADMIN=
BASE_TREASURY=
BASE_DEPLOYER=
BASE_PAUSER=
BASE_RESOLVER=
BASE_OPERATOR=
BASE_MARKET_CREATOR=
BASE_AGENT_RUNTIME_OPERATOR=
BASE_AGENT_RUNTIME_OPERATOR_PRIVATE_KEY=
BASE_GLOBAL_CLAIMER_PRIVATE_KEY=
AUTO_CLAIMER_PRIVATE_KEY=
AUTO_CLAIMER_POLL_INTERVAL_SEC=30
AUTO_CLAIMER_CANDIDATE_SCAN_LIMIT=1000
AUTO_CLAIMER_AGENT_SCAN_LIMIT=1000
AUTO_CLAIMER_ORDER_SCAN_WINDOW=2500
AUTO_CLAIMER_MAX_CLAIMS_PER_CYCLE=200
AUTO_CLAIMER_AUTO_WITHDRAW=false
AUTO_CLAIMER_OWNER_KEYS_FILE=
AUTO_CLAIMER_OWNER_KEYS_JSON=
BASE_MATCHER_PRIVATE_KEY=
MATCHER_ENABLED=true
MATCHER_INTERVAL_SEC=15
MATCHER_MAX_FILL_SIZE=1000000
MATCHER_RATE_LIMIT_PER_MARKET=1
MATCHER_MAX_MARKETS_PER_CYCLE=100
ADMIN_CONTROL_KEY=
BASE_IDENTITY_ISSUER=
BASE_REPUTATION_ATTESTER=
BASE_VALIDATION_MANAGER=
BASE_VALIDATION_VALIDATOR=
BOOTSTRAP_ADMIN=
RELAY_CAP_WEI=1000000000000000000000000000
RELAY_INITIAL_SUPPLY_WEI=100000000000000000000000000
COLLATERAL_TOKEN_BASE_MAINNET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
COLLATERAL_TOKEN_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
COLLATERAL_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Required for public Base write mode
RELAY_TOKEN_ADDRESS=0x580fF5Ae64eC792A949c6123386A8A936c7EBB07
MARKET_CORE_ADDRESS=0xc9259a18696Ecbf7636C1a01F40Bc9d47e249AE8
ORDER_BOOK_ADDRESS=0xFe8aA303Ab953037023b12326D354f6d2484D4ce
COLLATERAL_VAULT_ADDRESS=0x4420dd803e6E363e6af079e6b77CA03B93f8dAe0
AGENT_RUNTIME_ADDRESS=0xC44d686548513FF2a921201fa0811B1f30AA1a65
RELAY_STAKING_ADDRESS=0x709D6006f026950b531d4883260c8416650c5AB7
REWARD_DISTRIBUTOR_ADDRESS=0x3c4c0A74F9d108F966908a835a9b4b8D946bBce3
# Required if creator-funded bootstrap automation is enabled
BOOTSTRAP_OPERATOR_ADDRESS=
ERC8004_IDENTITY_REGISTRY_ADDRESS=0xda55218BC69C0cD52b4927F908606cB84D7ab994
ERC8004_REPUTATION_REGISTRY_ADDRESS=0x56636eE11F4c42272C669a0E6C1cdC63ADAbF03e
ERC8004_VALIDATION_REGISTRY_ADDRESS=0x095D11eE0AdEb7c3d5088f3FB7ea8ebB7d05A540
PROGRAM_VAULT_ADDRESS=0x4420dd803e6E363e6af079e6b77CA03B93f8dAe0
USDC_MINT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
EVM_ENABLED=true
EVM_READS_ENABLED=true
EVM_WRITES_ENABLED=true
INDEXER_LOOKBACK_BLOCKS=25000
INDEXER_CONFIRMATIONS=8

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
# Required only when Solana support is enabled
SOLANA_MARKET_PROGRAM_ID=
SOLANA_ORDERBOOK_PROGRAM_ID=
SOLANA_PRIVACY_PROGRAM_ID=
SOLANA_ENABLED=false
SOLANA_READS_ENABLED=false
SOLANA_WRITES_ENABLED=false

PUBLIC_API_URL=
NEXT_PUBLIC_API_URL=
SYNTHETIC_PROD_API_URL=
SYNTHETIC_PROD_WEB_URL=
SYNTHETIC_STAGING_API_URL=
SYNTHETIC_STAGING_WEB_URL=

# x402 premium data payments
X402_ENABLED=true
X402_RECEIVER_ADDRESS=0x0000000000000000000000000000000000000000
X402_FACILITATOR_URL=http://127.0.0.1:8081
X402_FACILITATOR_TOKEN=
X402_FACILITATOR_PRIVATE_KEY=
X402_FACILITATOR_SHARED_SECRET=
X402_ORDERBOOK_PRICE_MICROUSDC=2500
X402_TRADES_PRICE_MICROUSDC=2500
X402_MCP_PRICE_MICROUSDC=5000
X402_QUOTE_TTL_SECONDS=300

# External venues (Limitless + Polymarket)
EXTERNAL_MARKETS_ENABLED=true
EXTERNAL_TRADING_ENABLED=true
EXTERNAL_AGENTS_ENABLED=true
LIMITLESS_ENABLED=true
POLYMARKET_ENABLED=true
EXTERNAL_EXECUTION_MODE=live
ADMIN_WALLETS=
# Signer-backed bootstrap cron configuration
BASE_AGENT_OPERATOR_ENABLED=false
BASE_AGENT_OPERATOR_API_URL=http://127.0.0.1:8080/v1
BASE_AGENT_OPERATOR_PRIVATE_KEY=
BASE_AGENT_OPERATOR_SIWE_DOMAIN=localhost:3000
BASE_AGENT_OPERATOR_LIMIT=100
BASE_AGENT_OPERATOR_MIN_BALANCE_ETH=0.0002
# CDP wallet (alternative to raw private key — keys stay in Coinbase infra)
CDP_WALLET_ENABLED=false
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
CDP_WALLET_ID=
EXTERNAL_CREDENTIALS_MASTER_KEY=
EXTERNAL_CREDENTIALS_KEY_ID=v1
LIMITLESS_API_BASE=https://api.limitless.exchange
POLYMARKET_GAMMA_API_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_BASE=https://clob.polymarket.com
POLYGON_RPC_URL=https://polygon-rpc.com

# XMTP swarm runtime
# bridge process (`npm run xmtp:bridge`) requires Node.js >= 22
XMTP_SWARM_ENABLED=true
XMTP_SWARM_SIGNING_KEY=
XMTP_SWARM_TRANSPORT=xmtp_http
XMTP_SWARM_BRIDGE_URL=http://127.0.0.1:8090
XMTP_SWARM_TOPIC_PREFIX=relay44/base/swarm
XMTP_SWARM_MAX_MESSAGES=500
XMTP_SWARM_MAX_MESSAGE_BYTES=32768
SANCTIONS_BLOCKED_ADDRESSES=
XMTP_ENV=production
XMTP_WALLET_KEY=
XMTP_BRIDGE_HOST=0.0.0.0
XMTP_BRIDGE_PORT=8090
XMTP_DB_DIRECTORY=.cache/xmtp

# Integrations
RELAY_WEBHOOK_SECRET=
CORS_ORIGINS=http://localhost:3000
AUTH_ALLOWED_ORIGINS=http://localhost:3000
DX_TERMINAL_API_URL=https://api.terminal.markets
DX_TERMINAL_RPC_URL=https://mainnet.base.org
DX_TERMINAL_OWNER_ADDRESS=
DX_TERMINAL_VAULT_ADDRESS=
DX_TERMINAL_PRIVATE_KEY=

# Edge Scanner (calibration arb + time decay)
EDGE_SCANNER_ENABLED=false
EDGE_SCANNER_ADMIN_PRIVATE_KEY=
EDGE_SCANNER_API_URL=http://127.0.0.1:8080/v1
EDGE_SCANNER_DRY_RUN=true
EDGE_SCANNER_INTERVAL_MS=3600000
EDGE_SCANNER_MIN_CALIBRATION_EDGE_BPS=500
EDGE_SCANNER_MIN_DECAY_EDGE_BPS=400
EDGE_SCANNER_MIN_BUCKET_SAMPLES=20
EDGE_SCANNER_MIN_DAYS_REMAINING=7
EDGE_SCANNER_MAX_RESOLVED_PAGES=10
EDGE_SCANNER_MAX_ACTIVE_PAGES=5

# Server
HOST=127.0.0.1
PORT=8080
RUST_LOG=info
